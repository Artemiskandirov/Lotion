# Optional: enables AI-improved storyboards. Without a key the plugin uses the
# deterministic planner, which still produces varied animations per prompt.
OPENAI_API_KEY=

# Model id passed to OpenAI Responses API. Override if your account exposes a
# different name (e.g. gpt-5, gpt-5.5, gpt-4.1).
OPENAI_MODEL=gpt-5
