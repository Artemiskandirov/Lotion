{
  "name": "@lotion/figma-plugin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:plugin": "vite --host 127.0.0.1",
    "build": "next build",
    "build:plugin": "vite build && esbuild src/code.ts --bundle --target=es2020 --outfile=dist/code.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:plugin": "tsc -p tsconfig.plugin.json --noEmit"
  },
  "dependencies": {
    "@lotion/shared": "file:../../packages/shared",
    "@vitejs/plugin-react": "^4.3.0",
    "next": "^15.0.0",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
